# CONFORMITAS 3.0 — Environment Variables
# Copie este arquivo para .env e preencha os valores de produção
# NÃO commitar .env no repositório

# ── Ambiente ────────────────────────────────────────
NODE_ENV=development

# ── PostgreSQL ──────────────────────────────────────
POSTGRES_DB=conformitas_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=1800
REFRESH_EXPIRES_IN=28800

# ── MFA (TOTP) ──────────────────────────────────────
TOTP_ISSUER=CONFORMITAS-DEV

# ── Autenticação ────────────────────────────────────
AUTH_PROVIDER=local
# KEYCLOAK_URL=
# KEYCLOAK_REALM=conformitas
# KEYCLOAK_CLIENT_ID=conformitas-api
# KEYCLOAK_CLIENT_SECRET=

# ── Logging ─────────────────────────────────────────
LOG_LEVEL=debug

# ── Upload ──────────────────────────────────────────
UPLOAD_MAX_SIZE=25mb
UPLOAD_DIR=./uploads

# ── Keycloak (Opcional) ─────────────────────────────
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=admin
# KEYCLOAK_DB=keycloak
# KEYCLOAK_HOSTNAME=localhost

# ── URLs ────────────────────────────────────────────
API_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:4200
